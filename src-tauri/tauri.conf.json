{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EquiSound",
  "version": "2.3.0",
  "identifier": "de.rfv-leonberg.musiccontrol",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EquiSound",
        "width": 1024,
        "height": 700
      }
    ],

    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "RFV Leonberg",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fc21off/rfv-soundboard-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBRDk0OTBEREE1RTU1NDMKUldSRFZWN2FEVW5aYWlNQTJkbUJxODBqMGZJWEZ3emdSdjFqN3V5b3p4eDk0NkFUT2R1UEd2d2oK"
    }
  }
}
