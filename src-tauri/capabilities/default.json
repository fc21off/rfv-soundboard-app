{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "updater:default",
    "process:allow-restart"
  ]
}
